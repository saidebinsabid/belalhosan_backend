# Copy this file to ".env" and fill in the values.

# ── Server ───────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── CORS: Next.js client origin(s), comma-separated ──────
CLIENT_URL=http://localhost:3000,http://localhost:3001

# ── MongoDB ──────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/belalhosan
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/belalhosan
MONGODB_URI=

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
